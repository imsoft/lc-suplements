# ─── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host.neon.tech/lc-suplements?sslmode=require"

# ─── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="min-32-characters-random-string"
BETTER_AUTH_URL="https://lcsuplements.com"  # http://localhost:3000 en desarrollo

# ─── Cloudinary ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── MercadoPago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN="your-access-token"
MERCADOPAGO_PUBLIC_KEY="your-public-key"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="your-public-key"
MERCADOPAGO_WEBHOOK_SECRET="your-webhook-secret"

# ─── Resend (email transaccional) ─────────────────────────────────────────────
RESEND_API_KEY="re_your-api-key"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://lcsuplements.com"  # http://localhost:3000 en desarrollo
